# =========================
# SQL SERVER
# =========================
SQL_SERVER=localhost
SQL_DATABASE=Digital_Impact_Reportes
SQL_DRIVER=ODBC Driver 17 for SQL Server
SQL_TRUSTED_CONNECTION=yes
# Si usas usuario/password, cambia SQL_TRUSTED_CONNECTION=no
# SQL_USERNAME=mi_usuario
# SQL_PASSWORD=mi_password

# =========================
# GA4
# =========================
GA4_CREDENTIALS_FILE=credenciales.json
LOOKBACK_DAYS=365
# START_DATE=2025-05-04
# END_DATE=2026-05-04

# Prueba inicial con 2 properties:
PROPERTY_IDS_TO_RUN=407838284,427321367

GA4_PAGE_SIZE=10000
GA4_MAX_RETRIES=5
GA4_RETRY_BASE_SECONDS=5

# =========================
# OUTPUT
# =========================
LOAD_TO_SQL=true
SAVE_CSV_BACKUP=true
OUTPUT_DIR=outputs_ga4_sql_backup

# =========================
# GOOGLE SHEETS - ECOMMERCE GA4
# =========================
# Si el nombre no abre por permisos o duplicados, usa el ID del archivo.
GA4_ECOMMERCE_SPREADSHEET_NAME=Ecommerce-GA4
# GA4_ECOMMERCE_SPREADSHEET_ID=
GA4_CHANNEL_EQUIVALENCES_TABLE=dbo.Equivalencias_Canales
GA4_SHEETS_WRITE_CHUNK_ROWS=5000
GA4_SHEETS_RETRY_BASE_SECONDS=20
GA4_SHEETS_MAX_RETRIES=4
GA4_ECOMMERCE_START_DATE=2025-01-01
# GA4_ECOMMERCE_END_DATE=2026-05-29
