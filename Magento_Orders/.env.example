# Magento_Orders — consumidor del API de export del droplet
# Copiar a .env en esta carpeta (o usar el .env de la raíz del repo).

# API export (blueprint export_api en automatizaciones_solidez)
EXPORT_API_URL=https://api.novedadescoliseum.com.pe/api/export/orders
EXPORT_API_TOKEN=PEGAR_AQUI_EL_TOKEN_DEL_DROPLET

# Tuning (defaults razonables, normalmente no tocar)
# EXPORT_PAGE_SIZE=1000
# EXPORT_OVERLAP_DAYS=2
# EXPORT_WINDOW_DAYS=30
# EXPORT_HTTP_TIMEOUT=90
# EXPORT_DEFAULT_SINCE=2025-01-01

# SQL Server local (mismas convenciones que GA4)
# SQL_SERVER=localhost
# SQL_DATABASE=Digital_Impact_Reportes
# SQL_DRIVER=ODBC Driver 17 for SQL Server
# SQL_TRUSTED_CONNECTION=yes
