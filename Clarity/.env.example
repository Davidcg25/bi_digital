# =========================
# SQL SERVER
# =========================
SQL_SERVER=localhost
SQL_DATABASE=Digital_Impact_Reportes
SQL_DRIVER=ODBC Driver 17 for SQL Server
SQL_TRUSTED_CONNECTION=yes
# SQL_USERNAME=mi_usuario
# SQL_PASSWORD=mi_password

# =========================
# CLARITY
# =========================
CLARITY_NUM_OF_DAYS=3
CLARITY_MAX_WORKERS=4
CLARITY_MAX_RETRIES=3
CLARITY_RETRY_BASE_SECONDS=10
# Opcional: limitar marcas por nombre, separadas por coma
# CLARITY_PROJECTS_TO_RUN=Converse,Coliseum
# Opcional: limitar reportes, separados por coma
# CLARITY_REPORTS_TO_RUN=overview,by_device

# Las credenciales productivas viven en el .env raiz de BI:
# D:\Programs\1. Apps\7. Digital Impact\4. BI\.env
#
# Formato:
# CLARITY_PROJECT_KEYS=CONVERSE,COLISEUM
# CLARITY_PROJECT_CONVERSE_NAME=Converse
# CLARITY_PROJECT_CONVERSE_TOKEN_NAME=depor_reportes
# CLARITY_PROJECT_CONVERSE_TOKEN=...
# CLARITY_PROJECT_COLISEUM_NAME=Coliseum
# CLARITY_PROJECT_COLISEUM_TOKEN_NAME=depor_reportes
# CLARITY_PROJECT_COLISEUM_TOKEN=...

# =========================
# OUTPUT
# =========================
LOAD_TO_SQL=true
SAVE_JSON_BACKUP=true
OUTPUT_DIR=outputs_clarity_sql_backup
